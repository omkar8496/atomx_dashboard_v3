{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "out/**",
        "dist/**"
      ]
    },
    "lint": {
      "outputs": []
    }
  }
}
